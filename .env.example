# ─────────────────────────────────────────────────────────────────────────────
# JoinSkill — Environment Variables
# Copy this file to .env and fill in values before running locally.
# DO NOT commit the real .env file to source control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Backend (server/index.js) ─────────────────────────────────────────────────

# Port the Express + Socket.IO server listens on
PORT=5000

# Secret used to sign JWT tokens — use a long random string in production
JWT_SECRET=joinskill-local-secret-change-me

# Comma-separated list of allowed CORS origins (frontend URLs)
# Local dev:      http://localhost:5173,http://127.0.0.1:5173
# Production:     https://joinskill.netlify.app
CLIENT_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# ── Frontend (Vite build / src/App.jsx) ──────────────────────────────────────

# Base URL of the backend API — used by the React app at runtime
# Local dev:  leave blank (Vite proxy handles it) or set to http://127.0.0.1:5000
# Production: https://joinskill-api.onrender.com
VITE_API_URL=http://127.0.0.1:5000

# URL used by socket.io-client to connect — usually the same as VITE_API_URL
VITE_SOCKET_URL=http://127.0.0.1:5000
